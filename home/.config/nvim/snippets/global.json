{
  "Current datetime": {
    "prefix": "cdtm",
    "body": "$CURRENT_DATE.$CURRENT_MONTH.$CURRENT_YEAR. $CURRENT_HOUR:$CURRENT_MINUTE",
    "description": "Insert current datetime (dd.mm.YYYY. HH:MM)"
  },
  "Current date": {
    "prefix": "cdate",
    "body": "$CURRENT_DATE.$CURRENT_MONTH.$CURRENT_YEAR.",
    "description": "Insert current date (dd.mm.YYYY.)"
  },
  "Current time": {
    "prefix": "ctime",
    "body": "$CURRENT_HOUR:$CURRENT_MINUTE",
    "description": "Insert current time (HH:MM)"
  }
}
